{
  "name": "vendorbridge-backend",
  "version": "1.0.0",
  "description": "VendorBridge Procurement Management System — Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:reset": "psql -U $DB_USER -d $DB_NAME -h $DB_HOST -f model/schema.sql && psql -U $DB_USER -d $DB_NAME -h $DB_HOST -f model/triggers.sql && psql -U $DB_USER -d $DB_NAME -h $DB_HOST -f model/seed.sql",
    "db:schema": "psql -U $DB_USER -d $DB_NAME -h $DB_HOST -f model/schema.sql",
    "db:seed": "psql -U $DB_USER -d $DB_NAME -h $DB_HOST -f model/seed.sql"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.0.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}